---
# platform-defaults-secret.yaml.template
#
# This file is a TEMPLATE — copy it, fill in real values, then apply.
# The rendered file is gitignored — never commit real values.
#
# Home cluster ({{CLUSTER_NAME}} / dry-run):
#   Values from example-cluster-public.yaml are fine — dry-run never persists.
#   Run: cp platform-defaults-secret.yaml.template platform-defaults-secret.yaml
#   Then: kubectl apply -f platform-defaults-secret.yaml -n argo
#
# Work cluster (real provision):
#   Replace every <CHANGE_ME_...> with your actual Azure values.
#   Source them from: az identity show, az network vnet show, etc.

apiVersion: v1
kind: Secret
metadata:
  name: platform-defaults
  namespace: argo
  labels:
    kro.run/component: platform-defaults
    kro.run/demo: "true"
type: Opaque
stringData:
  # ── Azure subscription ─────────────────────────────────────────────────────
  SUBSCRIPTION_ID: "{{AZURE_SUBSCRIPTION_ID}}"

  # ── Networking ────────────────────────────────────────────────────────────
  VNET_SUBSCRIPTION_ID: "{{AZURE_SUBSCRIPTION_ID}}"
  VNET_RESOURCE_GROUP: "aks-cluster"
  VNET_NAME: "aks-vnet"
  SUBNET_NAME: "aks-subnet"
  SERVICE_CIDR: "10.251.0.0/17"
  DNS_SERVICE_IP: "10.251.0.10"
  POD_CIDR: "10.251.128.0/17"

  # ── Managed Identities ────────────────────────────────────────────────────
  CONTROL_PLANE_IDENTITY_RESOURCE_ID: "/subscriptions/{{AZURE_SUBSCRIPTION_ID}}/resourceGroups/rg-my-aks-cluster/providers/Microsoft.ManagedIdentity/userAssignedIdentities/my-aks-cluster-control-plane-identity"
  KUBELET_IDENTITY_CLIENT_ID: "{{AZURE_SUBSCRIPTION_ID}}"
  KUBELET_IDENTITY_OBJECT_ID: "{{AZURE_SUBSCRIPTION_ID}}"
  KUBELET_IDENTITY_RESOURCE_ID: "/subscriptions/{{AZURE_SUBSCRIPTION_ID}}/resourceGroups/rg-my-aks-cluster/providers/Microsoft.ManagedIdentity/userAssignedIdentities/my-aks-cluster-kubelet-identity"
  FLUX_CLIENT_ID: "{{AZURE_SUBSCRIPTION_ID}}"

  # ── AAD ───────────────────────────────────────────────────────────────────
  AAD_ADMIN_GROUP_OBJECT_ID: "{{AZURE_SUBSCRIPTION_ID}}"

  # ── Security ─────────────────────────────────────────────────────────────
  DEFENDER_WORKSPACE_RESOURCE_ID: "/subscriptions/{{AZURE_SUBSCRIPTION_ID}}/resourceGroups/aks-cluster/providers/Microsoft.OperationalInsights/workspaces/test-workspace"

  # ── SSH ───────────────────────────────────────────────────────────────────
  SSH_PUBLIC_KEY: "ssh-rsa "

  # ── Flux GitOps ──────────────────────────────────────────────────────────
  # Replace with real ADO/GitHub repo URLs for work cluster
  FLUX_CORE_URL: "https://dev.azure.com/your-org/uk8s-core/_git/uk8s-core"
  FLUX_CONFIG_URL: "https://dev.azure.com/your-org/uk8s-config/_git/uk8s-config"
