# K-Agent / Agent Gateway observability replication environment.
#
# Fill these values in a private .env file before giving the bundle to an
# agent. Keep this example file placeholder-only.

# Kubernetes targets.
KUBE_CONTEXT="{{KUBE_CONTEXT}}"
CLUSTER_NAME="{{CLUSTER_NAME}}"
MONITORING_NAMESPACE="monitoring"
KAGENT_NAMESPACE="kagent"
GATEWAY_NAMESPACE_REGEX="agentgateway-system|kgateway-system"
ARGO_EVENTS_NAMESPACE="argo-events"
ARGO_WORKFLOWS_NAMESPACE="argo"

# Managed or self-hosted LGTM endpoints.
# Prometheus remote_write requires a receiver-enabled Prometheus endpoint or
# Mimir-compatible push endpoint.
PROMETHEUS_REMOTE_WRITE_URL="{{PROMETHEUS_REMOTE_WRITE_URL}}"
LOKI_PUSH_URL="{{LOKI_PUSH_URL}}"

# Optional tenant/auth headers for remote_write and Loki push.
# Leave blank if the work stack does not require them.
PROMETHEUS_TENANT_ID="{{PROMETHEUS_TENANT_ID}}"
PROMETHEUS_REMOTE_WRITE_AUTH_HEADER="{{PROMETHEUS_REMOTE_WRITE_AUTH_HEADER}}"
PROMETHEUS_REMOTE_WRITE_BEARER_TOKEN_SECRET_NAME="{{PROMETHEUS_REMOTE_WRITE_BEARER_TOKEN_SECRET_NAME}}"
LOKI_TENANT_ID="{{LOKI_TENANT_ID}}"
LOKI_AUTH_HEADER="{{LOKI_AUTH_HEADER}}"
LOKI_BEARER_TOKEN_SECRET_NAME="{{LOKI_BEARER_TOKEN_SECRET_NAME}}"

# Grafana API and datasource configuration.
GRAFANA_URL="{{GRAFANA_URL}}"
GRAFANA_ORG_ID="1"
GRAFANA_PROMETHEUS_DATASOURCE_UID="{{GRAFANA_PROMETHEUS_DATASOURCE_UID}}"
GRAFANA_LOKI_DATASOURCE_UID="{{GRAFANA_LOKI_DATASOURCE_UID}}"
GRAFANA_ALERTMANAGER_DATASOURCE_UID="{{GRAFANA_ALERTMANAGER_DATASOURCE_UID}}"
GRAFANA_AUTH_MODE="basic"
GRAFANA_USER="{{GRAFANA_USER}}"
GRAFANA_PASSWORD="{{GRAFANA_PASSWORD}}"
GRAFANA_API_TOKEN="{{GRAFANA_API_TOKEN}}"

# Alert routing.
# Use the direct webhook when Alertmanager or Grafana can reach Argo Events.
ALERTMANAGER_WEBHOOK_URL="http://path-b-alertmanager-webhook-eventsource-svc.argo-events.svc:12000/alertmanager"
ARGO_EVENTSOURCE_WEBHOOK_URL="{{ARGO_EVENTSOURCE_WEBHOOK_URL}}"
GRAFANA_CONTACT_POINT_NAME="k-agent-argo-triage"
GRAFANA_CONTACT_POINT_UID="k-agent-argo-triage"

# Rule sync.
# Set to true only when Alloy has Mimir/Loki ruler credentials and the target
# environment supports rule sync.
ENABLE_MIMIR_RULE_SYNC="false"
ENABLE_LOKI_RULE_SYNC="false"
MIMIR_RULER_URL="{{MIMIR_RULER_URL}}"
LOKI_RULER_URL="{{LOKI_RULER_URL}}"
RULER_TENANT_ID="{{RULER_TENANT_ID}}"
RULER_AUTH_SECRET_NAME="{{RULER_AUTH_SECRET_NAME}}"

# Optional broker-backed contact point. Use only when direct webhook routing is
# blocked or when buffering/replay/fan-out is required.
ENABLE_BROKER_CONTACT_POINT="false"
BROKER_TYPE="{{BROKER_TYPE}}" # confluent|eventhub|redpanda|none
BROKER_BOOTSTRAP_SERVERS="{{BROKER_BOOTSTRAP_SERVERS}}"
BROKER_ALERTS_TOPIC="alertmanager-events"
BROKER_K8S_EVENTS_TOPIC="k8s-events"
BROKER_CONSUMER_GROUP="k-agent-alert-triage"
BROKER_AUTH_SECRET_NAME="{{BROKER_AUTH_SECRET_NAME}}"
CONFLUENT_REST_ENDPOINT="{{CONFLUENT_REST_ENDPOINT}}"
CONFLUENT_CLUSTER_ID="{{CONFLUENT_CLUSTER_ID}}"

# K-Agent triage endpoint.
KAGENT_CONTROLLER_URL="http://kagent-controller.kagent:8083"
KAGENT_TRIAGE_AGENT_NAME="sre-triage-agent"
KAGENT_TRIAGE_A2A_URL="http://kagent-controller.kagent:8083/api/a2a/kagent/sre-triage-agent/"

# Verification behavior.
RUN_SYNTHETIC_ALERT="false"
SYNTHETIC_ALERT_APPROVED_BY="{{APPROVER_OR_CHANGE_ID}}"
VERIFY_TIME_RANGE="24h"

# Notes for the agent.
AUTH_NOTES="{{WHERE_AUTH_TOKENS_OR_HEADERS_ARE_STORED}}"
NETWORK_NOTES="{{HOW_GRAFANA_ALERTING_OR_ALERTMANAGER_REACHES_ARGO_EVENTS}}"
CHANGE_CONTROL_NOTES="{{CHANGE_WINDOW_OR_APPROVAL_REFERENCE}}"
