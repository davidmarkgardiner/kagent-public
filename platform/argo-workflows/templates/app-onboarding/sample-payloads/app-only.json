{
  "metadata": {
    "name": "frontend-staging",
    "swc": "BB67890",
    "environment": "STAGING",
    "owner": "frontend-team",
    "costCenter": "CC-5678",
    "requestedBy": "jane.smith@company.com",
    "requestedAt": "2026-03-24T11:00:00Z"
  },
  "namespace": {
    "name": "frontend-staging",
    "createIfNotExists": true,
    "labels": {
      "team": "frontend",
      "project": "web-app"
    }
  },
  "resourceQuota": {
    "cpu": "4",
    "memory": "8Gi",
    "storage": "20Gi",
    "pods": "50"
  },
  "networkPolicy": {
    "defaultDeny": true,
    "allowFrom": ["istio-system", "monitoring"],
    "allowEgress": ["kube-dns", "istio-system"]
  },
  "serviceAccount": {
    "name": "frontend-sa",
    "workloadIdentity": {
      "enabled": false
    }
  },
  "rbac": {
    "teamAdGroup": "sg-frontend-devs",
    "clusterRole": "edit"
  },
  "application": {
    "name": "web-app",
    "image": "myregistry.azurecr.io/web-app:v1.2.3",
    "replicas": 2,
    "resources": {
      "requests": {
        "cpu": "250m",
        "memory": "512Mi"
      },
      "limits": {
        "cpu": "500m",
        "memory": "1Gi"
      }
    },
    "env": [
      { "name": "NODE_ENV", "value": "staging" },
      { "name": "LOG_LEVEL", "value": "info" }
    ],
    "ports": [
      { "name": "http", "containerPort": 3000 }
    ],
    "healthCheck": {
      "path": "/healthz",
      "port": 3000,
      "initialDelaySeconds": 10,
      "periodSeconds": 15
    },
    "configMap": {
      "name": "web-app-config",
      "data": {
        "API_URL": "https://api-staging.company.com",
        "FEATURE_FLAGS": "dark-mode,new-nav"
      }
    }
  },
  "networking": {
    "service": {
      "type": "ClusterIP",
      "port": 80,
      "targetPort": 3000
    }
  }
}
