#!/bin/sh
# Wrapper script to run validation with bash 5+ from nix
# Usage: ./validate-certification-coverage [path-to-rgd-yaml]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_PATH="$SCRIPT_DIR/validate-certification-coverage.sh"

# Try to find bash 5+ in various locations
if [ -x "/nix/store/a6akyvyh3j60yz9gajqbm155k2c7m5fc-bash-5.3p0/bin/bash" ]; then
    BASH_BIN="/nix/store/a6akyvyh3j60yz9gajqbm155k2c7m5fc-bash-5.3p0/bin/bash"
elif command -v bash >/dev/null 2>&1; then
    BASH_BIN=$(command -v bash)
    # Check if it's bash 4+
    VERSION=$($BASH_BIN --version | head -1 | grep -oE '[0-9]+\.[0-9]+' | head -1 | cut -d. -f1)
    if [ "$VERSION" -lt 4 ]; then
        echo "ERROR: bash 4+ required, found version $VERSION"
        echo ""
        echo "Please install bash 4+ or use devbox shell:"
        echo "  brew install bash   # macOS"
        echo "  devbox shell        # Use devbox environment"
        exit 1
    fi
else
    echo "ERROR: bash not found"
    exit 1
fi

# Execute the actual script with proper bash
exec "$BASH_BIN" "$SCRIPT_PATH" "$@"
