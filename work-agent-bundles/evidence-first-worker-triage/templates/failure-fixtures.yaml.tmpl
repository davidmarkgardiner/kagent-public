apiVersion: v1
kind: Pod
metadata: { name: ${PILOT_NAME}-log-error, namespace: ${WORKER_NAMESPACE}, labels: { app.kubernetes.io/name: ${PILOT_NAME}-log-error } }
spec:
  restartPolicy: Never
  containers:
  - name: app
    image: busybox:1.36
    command: [sh, -c, 'echo "ERROR unable to load ConfigMap pilot-config token=not-a-real-token"; sleep 30']
---
apiVersion: v1
kind: Pod
metadata: { name: ${PILOT_NAME}-oom, namespace: ${WORKER_NAMESPACE}, labels: { app.kubernetes.io/name: ${PILOT_NAME}-oom } }
spec:
  restartPolicy: Never
  containers:
  - name: app
    image: busybox:1.36
    resources: { limits: { memory: 32Mi } }
    command: [sh, -c, 'head -c 96M /dev/zero >/dev/null']
---
apiVersion: v1
kind: Pod
metadata: { name: ${PILOT_NAME}-unschedulable, namespace: ${WORKER_NAMESPACE}, labels: { app.kubernetes.io/name: ${PILOT_NAME}-unschedulable } }
spec:
  nodeSelector: { evidence-first-pilot-never-scheduled: "true" }
  containers: [{ name: app, image: busybox:1.36, command: [sh, -c, 'sleep 600'] }]
---
apiVersion: v1
kind: Pod
metadata: { name: ${PILOT_NAME}-image-pull, namespace: ${WORKER_NAMESPACE}, labels: { app.kubernetes.io/name: ${PILOT_NAME}-image-pull } }
spec:
  containers: [{ name: app, image: registry.invalid/evidence-first/does-not-exist:never }]
