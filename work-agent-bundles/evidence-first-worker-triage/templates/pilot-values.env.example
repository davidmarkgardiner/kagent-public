# Copy outside Git as pilot-values.env and replace every placeholder.
PILOT_NAME={{PILOT_NAME}}
ENVIRONMENT={{ENVIRONMENT}}
TENANT={{TENANT}}
WORKER_CLUSTER_NAME={{WORKER_CLUSTER_NAME}}
WORKER_NAMESPACE={{NON_PRODUCTION_NAMESPACE}}
MANAGEMENT_NAMESPACE={{MANAGEMENT_NAMESPACE}}
KAFKA_BOOTSTRAP={{KAFKA_BOOTSTRAP}}
KAFKA_AUTH_MODE={{MTLS_OR_SASL}}
KAFKA_TOPIC=triage.{{ENVIRONMENT}}.{{TENANT}}.evidence.v3
KAFKA_CONSUMER_GROUP={{MANAGEMENT_CONSUMER_GROUP}}
KAFKA_SECRET_NAME={{EXISTING_CONFLUENT_SECRET}}
KAFKA_BOOTSTRAP_KEY=bootstrap
KAFKA_USERNAME_KEY=key
KAFKA_PASSWORD_KEY=secret
KAFKA_CA_SECRET_NAME={{EXISTING_KAFKA_CA_SECRET}}
KAFKA_CA_SECRET_KEY=ca.pem
DURABLE_TTL_BACKEND={{APPROVED_TTL_BACKEND}}
IDEMPOTENCY_CLAIM_URL={{APPROVED_IDEMPOTENCY_CLAIM_URL}}
IDEMPOTENCY_SECRET_NAME={{EXISTING_IDEMPOTENCY_SECRET}}
IDEMPOTENCY_TOKEN_KEY=token
DATA_CLASSIFICATION_REFERENCE={{APPROVED_POLICY_REFERENCE}}
VECTOR_IMAGE={{APPROVED_VECTOR_IMAGE}}
VECTOR_BUFFER_SIZE={{APPROVED_BUFFER_SIZE}}
APPROVED_STORAGE_CLASS={{APPROVED_STORAGE_CLASS}}
WORKER_VECTOR_SERVICE_ACCOUNT={{EXISTING_VECTOR_SERVICE_ACCOUNT}}
ARGO_EVENTS_SERVICE_ACCOUNT={{EXISTING_ARGO_EVENTS_SERVICE_ACCOUNT}}
ARGO_WORKFLOW_SERVICE_ACCOUNT={{EXISTING_ARGO_WORKFLOW_SERVICE_ACCOUNT}}
KAGENT_A2A_URL={{READ_ONLY_KAGENT_A2A_URL}}
KAGENT_AGENT_NAME={{READ_ONLY_KAGENT_AGENT_NAME}}
GITLAB_SECRET_NAME={{EXISTING_GITLAB_SECRET}}
GITLAB_URL_KEY=url
GITLAB_TOKEN_KEY=token
GITLAB_PROJECT_ID_KEY=project-id
CRITIQUE_CORRECTIONS_ACCEPTED=no
