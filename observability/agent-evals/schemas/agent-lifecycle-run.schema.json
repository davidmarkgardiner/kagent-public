{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kagent-public.local/schemas/agent-lifecycle-run.schema.json",
  "title": "AgentLifecycleRun",
  "type": "object",
  "required": ["schemaVersion", "kind", "run_id", "case_id", "incident", "lifecycle", "hitl", "remediation", "verification", "ticket"],
  "properties": {
    "schemaVersion": { "const": "agent-evals.kagent-public/v1alpha1" },
    "kind": { "const": "AgentLifecycleRun" },
    "run_id": { "type": "string" },
    "case_id": { "type": "string" },
    "incident_id": { "type": "string" },
    "workflow_name": { "type": "string" },
    "trace_id": { "type": "string" },
    "started_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "duration_seconds": { "type": "integer", "minimum": 0 },
    "incident": {
      "type": "object",
      "required": ["namespace", "workload", "failure_mode"],
      "properties": {
        "namespace": { "type": "string" },
        "workload": { "type": "string" },
        "failure_mode": { "type": "string" },
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    },
    "lifecycle": {
      "type": "object",
      "required": ["alert_received", "triage_completed", "a2a_fanout_completed", "hitl_requested", "hitl_approved", "remediation_executed", "verification_passed", "ticket_updated"],
      "properties": {
        "alert_received": { "type": "boolean" },
        "triage_completed": { "type": "boolean" },
        "a2a_fanout_completed": { "type": "boolean" },
        "hitl_requested": { "type": "boolean" },
        "hitl_approved": { "type": "boolean" },
        "remediation_executed": { "type": "boolean" },
        "verification_passed": { "type": "boolean" },
        "ticket_updated": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "status": { "type": "string" },
          "trace_id": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "hitl": {
      "type": "object",
      "required": ["required", "requested", "approved"],
      "properties": {
        "required": { "type": "boolean" },
        "requested": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "approval_id": { "type": "string" },
        "decision": { "type": "string" }
      },
      "additionalProperties": true
    },
    "remediation": {
      "type": "object",
      "required": ["mode", "executed", "executed_after_hitl", "cluster_mutation_before_hitl"],
      "properties": {
        "mode": { "type": "string" },
        "executed": { "type": "boolean" },
        "executed_after_hitl": { "type": "boolean" },
        "cluster_mutation_before_hitl": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "verification": {
      "type": "object",
      "required": ["passed", "checks"],
      "properties": {
        "passed": { "type": "boolean" },
        "checks": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "ticket": {
      "type": "object",
      "required": ["system", "comment_added", "status_updated", "closed"],
      "properties": {
        "system": { "type": "string" },
        "id": { "type": "string" },
        "url": { "type": "string" },
        "comment_added": { "type": "boolean" },
        "status_updated": { "type": "boolean" },
        "closed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "a2a_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "status"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
