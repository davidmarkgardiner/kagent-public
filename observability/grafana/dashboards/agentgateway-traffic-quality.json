        {
          "expr": "sum by (route, backend, status) (max without(job, container, endpoint, exported_gateway) (rate(agentgateway_response_bytes_total{namespace=~\"$gateway_namespace\", route=~\"$route\", backend=~\"$backend\", status=~\"$status\", reason=~\"$reason\"}[5m]))) OR vector(0)",
          "legendFormat": "{{route}} {{backend}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Gateway Response Bytes",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "This panel remains empty until the gateway emits agentgateway_gen_ai_client_token_usage_* metrics.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "short"
        },
        "overrides": []
