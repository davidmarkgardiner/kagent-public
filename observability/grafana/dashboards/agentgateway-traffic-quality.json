      "targets": [
        {
          "expr": "topk(20, (sum by (route, backend) (max without(job, container, endpoint, exported_gateway) (increase(agentgateway_requests_total{namespace=~\"$gateway_namespace\", route=~\"$route\", backend=~\"$backend\", status=~\"5..\"}[24h])))) / (sum by (route, backend) (max without(job, container, endpoint, exported_gateway) (increase(agentgateway_requests_total{namespace=~\"$gateway_namespace\", route=~\"$route\", backend=~\"$backend\"}[24h])))))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Route Failure Ratio Last 24h",
      "type": "table"
