      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 9,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(20, sum by (route, backend, status, reason) (max without(job, container, endpoint, exported_gateway) (increase(agentgateway_requests_total{namespace=~\"$gateway_namespace\", route=~\"$route\", backend=~\"$backend\", status=~\"5..\", reason=~\"$reason\"}[24h]))))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Top Failed Routes Last 24h",
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(20, (sum by (route, backend, status, reason) (max without(job, container, endpoint, exported_gateway) (increase(agentgateway_request_duration_seconds_count{namespace=~\"$gateway_namespace\", route=~\"$route\", backend=~\"$backend\", status=~\"$status\", reason=~\"$reason\"}[24h])))) - (sum by (route, backend, status, reason) (max without(job, container, endpoint, exported_gateway) (increase(agentgateway_request_duration_seconds_bucket{namespace=~\"$gateway_namespace\", route=~\"$route\", backend=~\"$backend\", status=~\"$status\", reason=~\"$reason\", le=\"30.0\"}[24h])))))",
