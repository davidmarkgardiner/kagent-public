      },
      "targets": [
        {
          "expr": "sum by (gen_ai_request_model, gen_ai_token_type) (rate(agentgateway_gen_ai_client_token_usage_sum[5m]) * 60) OR vector(0)",
          "legendFormat": "{{gen_ai_request_model}} {{gen_ai_token_type}}",
          "refId": "A"
        }
      ],
      "title": "Token Usage Per Minute",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
