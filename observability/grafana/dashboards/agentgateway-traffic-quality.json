          "instant": true,
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Calls Slower Than 30s Last 24h",
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "Bps"
