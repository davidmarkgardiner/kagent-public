        "label": "Loki",
        "current": {
          "selected": false,
          "text": "kagent-loki",
          "value": "kagent-loki"
        },
        "refresh": 1
      },
      {
        "name": "kagent_namespace",
        "type": "custom",
        "label": "K-Agent namespace",
