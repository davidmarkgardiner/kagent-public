        "current": {
          "selected": false,
          "text": "chaos-demo|litmus",
          "value": "chaos-demo|litmus"
        },
        "options": [
          {
            "selected": true,
            "text": "chaos-demo|litmus",
            "value": "chaos-demo|litmus"
          }
        ]
      },
      {
        "name": "severity",
        "type": "custom",
        "label": "Severity",
        "query": ".*",
        "current": {
          "selected": false,
          "text": ".*",
          "value": ".*"
        },
        "options": [
          {
            "selected": true,
            "text": ".*",
            "value": ".*"
          }
        ]
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "K-Agent and Agent Gateway Observability",
  "uid": "k-agent-agentgateway-public-ready",
  "version": 1,
  "weekStart": ""
}
