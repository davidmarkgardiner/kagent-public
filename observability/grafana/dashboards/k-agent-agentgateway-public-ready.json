{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "target": {
          "limit": 100,
          "matchAny": false,
          "tags": [],
          "type": "dashboard"
        },
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=~\"$kagent_namespace\", phase=\"Running\"} == 1)",
          "legendFormat": "running",
          "refId": "A"
        }
      ],
      "title": "K-Agent Running Pods",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "Down"
                },
                "1": {
                  "color": "green",
                  "text": "Up"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "min(up{namespace=~\"$gateway_namespace\"})",
          "legendFormat": "gateway scrape",
          "refId": "A"
        }
      ],
      "title": "Gateway Metrics Scraped",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\", route_to=\"triage\"}) OR vector(0)",
          "legendFormat": "firing",
          "refId": "A"
        }
      ],
      "title": "Triage Alerts Firing",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"chaos-demo\", pod=~\".*(pod-delete|pod-cpu-hog|litmus).*\", phase=\"Succeeded\"} == 1)",
          "legendFormat": "completed",
          "refId": "A"
        }
      ],
      "title": "Chaos Runs Completed",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (namespace, pod, envoy_response_code_class) (rate(envoy_cluster_external_upstream_rq_xx{namespace=~\"$gateway_namespace\"}[5m]))",
          "legendFormat": "{{namespace}} {{pod}} {{envoy_response_code_class}}xx",
          "refId": "A"
        }
      ],
      "title": "Agent Gateway Response Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "targets": [
        {
          "expr": "(sum(rate(envoy_cluster_external_upstream_rq_xx{namespace=~\"$gateway_namespace\", envoy_response_code_class=\"5\"}[5m])) / clamp_min(sum(rate(envoy_cluster_external_upstream_rq_completed{namespace=~\"$gateway_namespace\"}[5m])), 1)) OR vector(0)",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ],
      "title": "Agent Gateway 5xx Ratio (0 is healthy)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "yellow",
                  "text": "not emitted"
                }
              },
              "type": "value"
            }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "targets": [
        {
          "expr": "count(agentgateway_gen_ai_client_token_usage_sum) OR vector(0)",
          "legendFormat": "series",
          "refId": "A"
        }
      ],
      "title": "Agent Gateway Token Metrics Available",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (namespace, pod, envoy_response_code_class) (rate(envoy_cluster_external_upstream_rq_xx{namespace=~\"$gateway_namespace\"}[5m]))",
          "legendFormat": "{{namespace}} {{pod}} {{envoy_response_code_class}}xx",
          "refId": "A"
        }
      ],
      "title": "Agent Gateway Response Rate by Pod",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum by (namespace, pod, container) (increase(kube_pod_container_status_restarts_total{namespace=~\"$kagent_namespace|$gateway_namespace|$chaos_namespace\"}[1h]))",
          "legendFormat": "{{namespace}} {{pod}} {{container}}",
          "refId": "A"
        }
      ],
      "title": "Restarts Last Hour",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "id": 10,
      "targets": [
        {
          "expr": "round(max by (phase) (increase(argo_workflows_total_count{exported_namespace=\"argo\"}[24h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Argo Workflow Outcomes Last 24h",
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "not ready"
                },
                "1": {
                  "color": "green",
                  "text": "ready"
                }
              },
              "type": "value"
            }
          ],
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "id": 11,
      "targets": [
        {
          "expr": "max(kube_pod_status_ready{namespace=\"monitoring\",pod=\"loki-0\",condition=\"true\"}) OR vector(0)",
          "legendFormat": "loki-0",
          "refId": "A"
        }
      ],
      "title": "Loki Backend Ready",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "not ready"
                },
                "1": {
                  "color": "green",
                  "text": "ready"
                }
              },
              "type": "value"
            }
          ],
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "id": 12,
      "targets": [
        {
          "expr": "max(kube_pod_status_ready{namespace=\"monitoring\",pod=~\"loki-gateway-.*\",condition=\"true\"}) OR vector(0)",
          "legendFormat": "loki-gateway",
          "refId": "A"
        }
      ],
      "title": "Loki Gateway Ready",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "id": 13,
      "targets": [
        {
          "expr": "kube_pod_status_ready{namespace=\"monitoring\",pod=~\"loki.*\",condition=\"true\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Loki Pod Readiness",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "id": 14,
      "targets": [
        {
          "expr": "max by (node) (kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Cluster Node Readiness",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "id": 15,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, namespace, pod, envoy_cluster_name) (rate(envoy_cluster_external_upstream_rq_time_bucket{namespace=~\"$gateway_namespace\"}[5m])))",
          "legendFormat": "{{namespace}} {{pod}} {{envoy_cluster_name}}",
          "refId": "A"
        }
      ],
      "title": "Agent Gateway Upstream Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 44
      },
      "id": 16,
      "targets": [
        {
          "expr": "round(max by (phase) (increase(argo_workflows_total_count{exported_namespace=\"argo\"}[24h])))",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ],
      "title": "Argo Workflow Outcomes Last 24h",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "kagent",
    "cage",
    "agentgateway",
    "alloy",
    "argo-events",
    "chaos"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource_prom",
